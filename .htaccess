Options -Indexes
RewriteEngine On

# Redirect bare root to the app
RewriteRule ^$ /lottery-app/dist/ [R=302,L]

# Let real files/folders pass through (api, uploads, lottery-app/dist assets)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# All other routes (React Router paths like /search, /admin, /history)
# → serve the React app index.html internally (no redirect)
RewriteRule ^ /lottery-app/dist/index.html [L]

# Block access to sensitive files
<FilesMatch "\.(sql|sh|env|log|bak|md)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(seed\.php|config\.php)$">
    Require all denied
</FilesMatch>
