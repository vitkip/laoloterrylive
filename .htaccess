Options -Indexes
DirectoryIndex lottery-app/dist/index.html

RewriteEngine On
RewriteBase /

# Explicitly pass through api/ and uploads/ — never rewrite these
RewriteRule ^(api|uploads)/ - [L]

# Let real files/folders pass through (lottery-app dist assets)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# All routes (including /) → serve the React SPA index.html (internal, no redirect)
RewriteRule ^ /lottery-app/dist/index.html [L]

# Block access to sensitive files
<FilesMatch "\.(sql|sh|env|log|bak|md)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(seed\.php|config\.php)$">
    Require all denied
</FilesMatch>
