    "/index.php?action=visitor_stats": {
      "get": {
        "tags": ["Analytics"],
        "summary": "ສະຖິຕິຜູ້ເຂົ້າຊົມ (admin only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "action", "in": "query", "required": true, "schema": { "type": "string", "enum": ["visitor_stats"] } }
        ],
        "responses": {
          "200": {
            "description": "Visitor stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total":           { "type": "integer" },
                    "unique_sessions": { "type": "integer" },
                    "today":           { "type": "integer" },
                    "today_unique":    { "type": "integer" },
                    "this_week":       { "type": "integer" },
                    "this_month":      { "type": "integer" },
                    "daily": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "day":              { "type": "string", "format": "date" },
                          "visits":           { "type": "integer" },
                          "unique_visitors":  { "type": "integer" }
                        }
                      }
                    },
                    "top_pages": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "page_path": { "type": "string" },
                          "visits":    { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },

