; =================================================================
; Lao Lottery Pro — Backend Environment Variables
; Generated: 2026-05-30
;
; SECURITY:
;   - NEVER commit this file to git (.gitignore must include api/.env)
;   - On cPanel: place this file one directory ABOVE public_html
;     and update the path in env.php accordingly
;   - On XAMPP local dev: this file is fine here since it is
;     protected by api/.htaccess (deny all for .env)
;
; HOW TO USE:
;   Copy this file to api/.env and fill in your real values.
;   api/env.php will parse this file and define constants.
; =================================================================

; ── Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=lao_lottery_pro

; ── JWT ────────────────────────────────────────────────────────────
; Generate a new secret: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET

; Access token lifetime in seconds (recommended: 900 = 15 minutes)
JWT_ACCESS_TTL=900

; Refresh token lifetime in seconds (recommended: 604800 = 7 days)
JWT_REFRESH_TTL=604800

; ── SMTP ───────────────────────────────────────────────────────────
SMTP_HOST=mail.laolots.com
SMTP_PORT=465
SMTP_USER=noreply@laolots.com
SMTP_PASS=REPLACE_WITH_REAL_SMTP_PASSWORD
SMTP_FROM=noreply@laolots.com
SMTP_FROM_NAME=Lao Lottery Live

; ── App ────────────────────────────────────────────────────────────
APP_URL=https://laolots.com
PRODUCTION=true

; ── Allowed CORS Origins (comma-separated) ─────────────────────────
ALLOWED_ORIGINS=https://laolots.com,https://www.laolots.com
